{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts",
    "helpers/**/*.ts",
    "fixtures/**/*.ts"
  ],
    "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}
